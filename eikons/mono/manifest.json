{
  "kind": "eikon.package",
  "schemaVersion": "1.0",
  "id": "liftaris/mono",
  "name": "mono",
  "display": {
    "title": "mono",
    "author": "kaio",
    "glyph": "◐"
  },
  "compatibility": {
    "eikon": ">=2 <3"
  },
  "entrypoints": {
    "default": "mono.eikonl"
  },
  "files": [
    {
      "path": "mono.eikonl",
      "mediaType": "application/vnd.eikon.stream+jsonl",
      "role": "stream"
    },
    {
      "path": "base.png",
      "role": "source"
    },
    {
      "path": "states/idle/loop.mp4",
      "role": "source"
    },
    {
      "path": "states/listening/loop.mp4",
      "role": "source"
    },
    {
      "path": "states/thinking/start.mp4",
      "role": "source"
    },
    {
      "path": "states/speaking/loop.mp4",
      "role": "source"
    },
    {
      "path": "states/working/loop.mp4",
      "role": "source"
    },
    {
      "path": "states/error/start.mp4",
      "role": "source"
    }
  ],
  "signals": {
    "state.idle": {
      "clip": "idle",
      "fallback": "state.idle"
    },
    "state.listening": {
      "clip": "listening",
      "fallback": "state.idle"
    },
    "state.thinking": {
      "clip": "thinking",
      "fallback": "state.idle"
    },
    "state.speaking": {
      "clip": "speaking",
      "fallback": "state.idle"
    },
    "state.working": {
      "clip": "working",
      "fallback": "state.idle"
    },
    "state.error": {
      "clip": "error",
      "fallback": "state.idle"
    }
  },
  "extensions": {
    "used": [
      "eikon.signals.v1"
    ]
  },
  "legacy": {
    "sourceFormat": ".eikon",
    "migration": "converted",
    "notes": [
      "moved legacy metadata: author, created, source_url"
    ]
  },
  "source": {
    "base": "base.png",
    "states": {
      "idle": {
        "file": "states/idle/loop.mp4"
      },
      "listening": {
        "file": "states/listening/loop.mp4"
      },
      "thinking": {
        "file": "states/thinking/start.mp4"
      },
      "speaking": {
        "file": "states/speaking/loop.mp4"
      },
      "working": {
        "file": "states/working/loop.mp4"
      },
      "error": {
        "file": "states/error/start.mp4"
      }
    }
  }
}
