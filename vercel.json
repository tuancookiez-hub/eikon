{
  "buildCommand": "bun run web:build",
  "ignoreCommand": "bash scripts/vercel-ignore.sh",
  "outputDirectory": "dist/web",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://*.supabase.co http://127.0.0.1:55321 http://localhost:55321; frame-src https://github.com; base-uri 'self'; frame-ancestors 'none'" }
      ]
    },
    {
      "source": "/packages/(.*)/blobs/sha256/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type", "value": "application/vnd.eikon.stream+jsonl" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/gallery/(.*)", "destination": "/index.html" },
    { "source": "/upload", "destination": "/index.html" },
    { "source": "/account", "destination": "/index.html" },
    { "source": "/auth/callback", "destination": "/index.html" }
  ]
}
