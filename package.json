{
  "name": "eikon",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./stream": "./src/stream/index.ts",
    "./package": "./src/package/index.ts",
    "./catalog": "./src/catalog.ts",
    "./install": "./src/install.ts",
    "./source": "./src/source.ts",
    "./lifecycle": "./src/lifecycle.ts",
    "./submit": "./src/publish.ts",
    "./registry/supabase": "./src/registry/supabase/index.ts",
    "./browser": "./src/browser.ts",
    "./player": "./src/web/player.tsx"
  },
  "scripts": {
    "browse": "bun run src/browse/main.tsx",
    "sshd": "bun run src/browse/sshd.tsx",
    "index": "bun src/cli.tsx index",
    "manifest": "bun src/cli.tsx manifest",
    "verify:artifacts": "bun src/cli.tsx verify",
    "web:dev": "vite --config vite.config.ts",
    "web:build": "bun run src/web/build.ts",
    "web:preview": "vite preview --config vite.config.ts --host 127.0.0.1",
    "test:web": "vitest run --config vite.config.ts",
    "supabase:types": "supabase gen types typescript --local --schema public,storage > src/registry/supabase/database.types.ts",
    "supabase:smoke": "bun scripts/supabase-smoke.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "bin": {
    "eikon": "./src/cli.tsx"
  },
  "dependencies": {
    "@opentui/core": "^0.1.99",
    "@opentui/react": "^0.1.99",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "typescript": "^5",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
