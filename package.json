{
  "name": "eikon",
  "type": "module",
  "license": "MIT",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./stream": "./src/stream/index.ts",
    "./package": "./src/package/index.ts",
    "./catalog": "./src/catalog.ts",
    "./install": "./src/install.ts",
    "./source": "./src/source.ts",
    "./lifecycle": "./src/lifecycle.ts",
    "./submit": "./src/publish.ts",
    "./browser": "./src/browser.ts",
    "./player": "./src/web/player.tsx"
  },
  "scripts": {
    "browse": "bun run src/browse/main.tsx",
    "sshd": "bun run src/browse/sshd.tsx",
    "index": "bun src/cli.tsx index",
    "manifest": "bun src/cli.tsx manifest",
    "verify:artifacts": "bun src/cli.tsx verify",
    "web:build": "bun run src/web/build.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "bin": {
    "eikon": "./src/cli.tsx"
  },
  "dependencies": {
    "@opentui/core": "^0.1.99",
    "@opentui/react": "^0.1.99",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.0",
    "typescript": "^5"
  }
}
